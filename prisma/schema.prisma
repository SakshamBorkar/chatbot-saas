generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ── RAG: Website Knowledge Base ───────────────────────────────────────────────

model Website {
  id         String   @id @default(uuid())
  botId      String   @map("bot_id")
  url        String
  status     String   @default("pending") // pending | crawling | ready | error
  crawledAt  DateTime? @map("crawled_at")
  createdAt  DateTime @default(now()) @map("created_at")

  bot   Bot    @relation(fields: [botId], references: [botId])
  pages Page[]

  @@unique([botId, url])
  @@map("websites")
}

model Page {
  id        String   @id @default(uuid())
  websiteId String   @map("website_id")
  url       String
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  website Website @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  chunks  Chunk[]

  @@unique([websiteId, url])
  @@map("pages")
}

model Chunk {
  id        String                      @id @default(uuid())
  pageId    String                      @map("page_id")
  content   String
  embedding Unsupported("vector(1536)")?
  createdAt DateTime                    @default(now()) @map("created_at")

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@map("chunks")
}

model Bot {
  id            String   @id @default(uuid())
  botId         String   @unique @map("bot_id")
  customerName  String   @map("customer_name")
  active        Boolean  @default(true)
  industry      String   @default("general")
  theme         String   @default("light")
  primaryColor  String   @default("#2563eb") @map("primary_color")
  createdAt     DateTime @default(now()) @map("created_at")

  conversations Conversation[]
  analytics     Analytics[]
  websites      Website[]
  user          User?


  @@map("bots")
}

model Conversation {
  id        String   @id @default(uuid())
  botId     String   @map("bot_id")
  sessionId String   @map("session_id")
  createdAt DateTime @default(now()) @map("created_at")

  bot      Bot       @relation(fields: [botId], references: [botId])
  messages Message[]

  @@map("conversations")
}

model Message {
  id             String   @id @default(uuid())
  conversationId String   @map("conversation_id")
  role           String   // "user" | "assistant"
  content        String
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id])

  @@map("messages")
}

model Analytics {
  id        String   @id @default(uuid())
  botId     String   @map("bot_id")
  eventType String   @map("event_type") // widget_loaded | widget_opened | message_sent | message_received
  sessionId String?  @map("session_id")
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  bot Bot @relation(fields: [botId], references: [botId])

  @@map("analytics")
}

// ── User Auth ─────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  name         String
  phone        String
  email        String   @unique
  sessionToken String?  @unique @map("session_token")
  botId        String   @unique @map("bot_id")
  createdAt    DateTime @default(now()) @map("created_at")
  industry     String   @default("general")

  bot Bot @relation(fields: [botId], references: [botId])

  @@map("users")
}

// ── Email OTP Verification ──────────────────────────────────────────────────

model OtpCode {
  id        String   @id @default(uuid())
  email     String
  code      String
  // "signup" | "login"
  purpose   String
  // Pending signup details stored as JSON until OTP is verified
  payload   String?
  expiresAt DateTime @map("expires_at")
  consumed  Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email, purpose])
  @@map("otp_codes")
}